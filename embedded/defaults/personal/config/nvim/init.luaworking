------------------------------------------------------------
-- Neoclip (FIXED: do not hard-crash if sqlite/telescope extension isn't ready)
--
-- Your screenshot shows: "Failed to run `config` for nvim-neoclip.lua"
-- That happens when:
--  - sqlite.lua isn't installed/compiled, or
--  - telescope isn't loaded when load_extension runs, or
--  - persistent history is enabled but sqlite backend isn't available.
--
-- This config:
--  - tries to require sqlite, and only enables persistent history if it exists
--  - pcall() wraps telescope extension load
------------------------------------------------------------
table.insert(spec, {
  "AckslD/nvim-neoclip.lua",
  dependencies = {
    "kkharji/sqlite.lua",
    "nvim-telescope/telescope.nvim",
  },
  event = "VeryLazy",
  config = function()
    local has_sqlite = pcall(require, "sqlite")

    require("neoclip").setup({
      history = 1000,
      enable_persistent_history = has_sqlite,
    })

    pcall(function()
      require("telescope").load_extension("neoclip")
    end)

    vim.keymap.set("n", "<leader>v", function()
      -- if extension isn't loaded for some reason, don't explode
      local ok = pcall(function()
        require("telescope").extensions.neoclip.default()
      end)
      if not ok then
        vim.notify("Neoclip: telescope extension not loaded (try :Lazy sync).", vim.log.levels.WARN)
      end
    end, { desc = "Clipboard history" })
  end,
})

