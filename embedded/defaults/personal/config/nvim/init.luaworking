-- lazy setup (spec)
------------------------------------------------------------
local spec = {
  { "LazyVim/LazyVim", import = "lazyvim.plugins" },
}

for _, s in ipairs(theme_spec) do
  table.insert(spec, s)
end

-- disable news alerts
table.insert(spec, {
  "LazyVim/LazyVim",
  opts = function(_, opts)
    opts = opts or {}
    opts.news = { lazyvim = false, neovim = false }
    return opts
  end,
})

