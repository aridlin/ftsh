local map = vim.keymap.set

-- Guarded file tree toggle:
-- Neo-tree if available, else NvimTree. BOTH go through the same cap.
map("n", "<leader>e", function()
  local root = guarded_root_or_warn()
  if not root then return end

  if vim.fn.exists(":Neotree") == 2 then
    vim.cmd("Neotree toggle dir=" .. vim.fn.fnameescape(root))
    return
  end

  if vim.fn.exists(":NvimTreeToggle") == 2 then
    -- Prefer API so we can open at a given path (and avoid cwd weirdness)
    local ok_api, api = pcall(require, "nvim-tree.api")
    if ok_api then
      api.tree.open({ path = root, focus = true })
    else
      -- fallback
      vim.cmd("cd " .. vim.fn.fnameescape(root))
      vim.cmd("NvimTreeToggle")
    end
    return
  end

  vim.notify("No file tree plugin available (:Neotree or :NvimTreeToggle).", vim.log.levels.WARN)
end, { desc = "Toggle file tree (guarded + capped)" })

