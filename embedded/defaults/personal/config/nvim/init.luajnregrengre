------------------------------------------------------------
-- Guardrails: prevent "open tree at root" and cap huge dirs
------------------------------------------------------------
local uv = vim.uv or vim.loop

local function normpath(p)
  if not p or p == "" then return "" end
  if vim.fs and vim.fs.normalize then
    return vim.fs.normalize(p)
  end
  return (p:gsub("\\", "/"))
end

local function is_dangerous_root(p)
  p = normpath(p)
  if p == "/" then return true end               -- Linux root
  if p:match("^%a:[/\\]?$") then return true end -- Windows drive root: C:\ or C:/
  if p:match("^/mnt/%a/?$") then return true end -- WSL drive root: /mnt/c
  return false
end

-- Hard cap: refuse opening tree in dirs with more than this many entries
local NVIMTREE_MAX_ENTRIES = 5000

local function count_dir_entries(path, max_count)
  max_count = max_count or NVIMTREE_MAX_ENTRIES
  local iter, err = uv.fs_scandir(path)
  if not iter then
    return nil, ("fs_scandir failed: %s"):format(err or "unknown")
  end

  local n = 0
  while true do
    local name = uv.fs_scandir_next(iter)
    if not name then break end
    n = n + 1
    if n > max_count then
      return n, nil -- early stop
    end
  end
  return n, nil
end

local function project_root()
  if vim.fs and vim.fs.root then
    local root = vim.fs.root(0, {
      ".git",
      "package.json",
      "pyproject.toml",
      "Cargo.toml",
      "go.mod",
      "CMakeLists.txt",
      "Makefile",
    })
    if root and root ~= "" then return root end
  end

  local buf = vim.api.nvim_buf_get_name(0)
  if buf ~= "" then
    return vim.fn.fnamemodify(buf, ":p:h")
  end

  return uv.cwd()
end

local function guarded_root_or_warn()
  local root = project_root()
  if not root or root == "" then root = uv.cwd() end

  if is_dangerous_root(root) then
    vim.notify(
      ("Refusing to open file tree at drive/root (%s). cd into a project folder first."):format(root),
      vim.log.levels.WARN
    )
    return nil
  end

  local n, err = count_dir_entries(root, NVIMTREE_MAX_ENTRIES)
  if not n then
    -- If we can't count, still allow, but warn.
    vim.notify(("Tree guard: couldn't count entries in %s (%s)."):format(root, err), vim.log.levels.WARN)
    return root
  end

  if n > NVIMTREE_MAX_ENTRIES then
    vim.notify(
      ("Refusing to open tree in %s (>%d entries; counted at least %d)."):format(root, NVIMTREE_MAX_ENTRIES, n),
      vim.log.levels.ERROR
    )
    return nil
  end

  return root
end

-- If you start Neovim inside / or C:\ etc, escape to ~ immediately
do
  local cwd = uv.cwd()
  if cwd and is_dangerous_root(cwd) then
    local home = vim.fn.expand("~")
    pcall(vim.cmd, "cd " .. vim.fn.fnameescape(home))
    vim.schedule(function()
      vim.notify(("CWD was %s (dangerous). Auto-cd to %s."):format(cwd, home), vim.log.levels.WARN)
    end)
  end
end

