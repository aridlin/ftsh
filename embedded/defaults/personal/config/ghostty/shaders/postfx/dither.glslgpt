// Simple Bayer dithering effect
// Use Ghostty background-opacity for transparency.
// This shader DOES NOT use alpha, so it will not delete dark Neovim colors.

const float bayerPattern[4] = float[4](
    0x0514,
    0xC4E6,
    0x3B19,
    0xF7D5
);

float getBayerFromPacked(int x, int y) {
    return float(
        (int(bayerPattern[y & 3]) >> ((x & 3) << 2)) & 0xF
    ) * (1.0 / 16.0);
}

#define LEVELS 28.0
#define INV_LEVELS (1.0 / LEVELS)

void mainImage(out vec4 fragColor, in vec2 fragCoord)
{
    vec2 uv = fragCoord / iResolution.xy;
    vec3 color = texture(iChannel0, uv).rgb;

    // Darken whole final image
    color *= 0.65;

    // Slight contrast
    color = pow(color, vec3(0.9));

    float threshold = getBayerFromPacked(
        int(fragCoord.x),
        int(fragCoord.y)
    );

    float ditherStrength = 1.2;

    vec3 dithered = floor(
        color * LEVELS + threshold * ditherStrength
    ) * INV_LEVELS;

    // IMPORTANT:
    // Keep alpha at 1.0.
    // Do not make dark pixels transparent.
    fragColor = vec4(dithered, 1.0);
}
