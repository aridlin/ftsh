# Initialization code that may require console input (password prompts, [y/n]
# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# confirmations, etc.) must go above this block; everything else may go below.
export LANG="${LANG:-C.UTF-8}"
export LC_CTYPE="${LC_CTYPE:-$LANG}"

if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Try to source Omarchy ZSH defaults (if Omarchy provides them)
for f in \
  "$HOME/.local/share/omarchy/default/zsh/rc" \
  "$HOME/.local/share/omarchy/default/zsh/.zshrc" \
  "$HOME/.local/share/omarchy/default/zsh/zshrc"
do
  [[ -r "$f" ]] && source "$f" && break
done

bindkey "^[[1;5C" forward-word   # Ctrl+вҶ’
bindkey "^[[1;5D" backward-word  # Ctrl+вҶҗ

autoload -Uz compinit
compinit

for f in \
  /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh \
  /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
do
  [[ -r "$f" ]] && source "$f" && break
done

for f in \
  /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh \
  /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
do
  [[ -r "$f" ]] && source "$f" && break
done
