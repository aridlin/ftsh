swayhelp() {
  local K='\033[1;33m'  # Yellow keybind
  local D='\033[0m'      # Default color
  local TITLE='\033[38;5;208m' # Orange title
  printf "${TITLE}в”Ҹв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ SWAY KEY CHEAT SHEET в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”“${D}\n"
  printf "${K}вҠһ + E        ${D} Launch terminal (foot)\n"
  printf "${K}вҠһ + Shift + E    ${D} Kill focused window\n"
  printf "${K}вҠһ + A / S / W / D${D} Focus left / down / up / right\n"
  printf "${K}вҠһ + Shift + A/S/W/D ${D} Move window left/down/up/right\n"
  printf "${K}вҠһ + V / B        ${D} Split vertically / horizontally\n"
  printf "${K}вҠһ + I / O / P    ${D} Layout: stacking / tabbed / toggle split\n"
  printf "${K}вҠһ + Space        ${D} Toggle floating\n"
  printf "${K}вҠһ + F            ${D} Fullscreen toggle\n"
  printf "${K}вҠһ + 1..9         ${D} Switch workspace 1-9\n"
  printf "${K}вҠһ + Shift + 1..9 ${D} Move window to workspace 1-9\n"
  printf "${K}вҠһ + Shift + C    ${D} Reload config\n"
  printf "${K}вҠһ + Shift + dont remember    ${D} Exit Sway\n"
  printf "${K}вҠһ + Ctrl + f    ${D} Thunar file manager\n"
  printf "${K}вҠһ + Ctrl + v    ${D} Volume\n"
  printf "${K}вҠһ + Ctrl + p    ${D} Flameshot\n"
  printf "${K}вҠһ + Ctrl + m    ${D} Music\n"
  printf "${K}вҠһ + Ctrl + e    ${D} Open mousepad\n"
  printf "${K}вҠһ + Shift + k   ${D} Light mode\n"
  printf "${K}вҠһ + Shift + l   ${D} Dark Mode\n"
  printf "${TITLE}в”—в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”ӣ${D}\n"
}

